{
  "name": "multica",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:web": "pnpm --filter @multica/workspace dev",
    "dev:workspace": "pnpm --filter @multica/workspace dev",
    "dev:air": "bash scripts/dev-air.sh",
    "build": "pnpm --filter @multica/workspace build",
    "typecheck": "pnpm --filter @multica/workspace typecheck",
    "test": "pnpm --filter @multica/workspace test",
    "lint": "pnpm --filter @multica/workspace lint",
    "clean": "rm -rf apps/workspace/dist node_modules"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "@types/react": "catalog:",
      "@types/react-dom": "catalog:"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "pg": "^8.20.0",
    "typescript": "catalog:"
  }
}
