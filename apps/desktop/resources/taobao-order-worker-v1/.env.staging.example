APP_NAME=taobao-order-worker-v1
ENV=staging
HOST=0.0.0.0
PORT=8090

# Use strong random values locally or in your secret manager. Do not commit real values.
TAOBAO_EVENT_SECRET=replace-with-strong-random-event-secret
ORDER_BRIDGE_API_TOKEN=replace-with-strong-random-bridge-token
REQUIRE_ORDER_BRIDGE_API_AUTH=true

# Copy from the Multica Autopilot webhook settings for the staging workspace.
MULTICA_AUTOPILOT_WEBHOOK_URL=https://your-multica-host/api/webhooks/autopilots/awt_xxx

# URL exposed to Multica Agent Runtime.
ORDER_BRIDGE_BASE_URL=http://localhost:8090

# Staging order API. Keep real tokens out of Git and chats.
ORDER_API_BASE_URL=https://your-staging-order-api.example.com
ORDER_API_TOKEN=replace-with-staging-token-from-local-env-or-secret-manager
ORDER_API_GET_ORDER_PATH=/api/orders/{tid}
ORDER_API_TIMEOUT_SECONDS=10
ORDER_API_AUTH_HEADER=Authorization
ORDER_API_AUTH_SCHEME=Bearer

# First real integration pass must remain read-only. Enable only after read-only checks pass.
ORDER_API_WRITE_THROUGH=false

DEDUPE_DB_PATH=./data/order_worker_staging.sqlite3
ALLOW_PLAIN_RECEIVER_INFO=true
STORE_PLAIN_RECEIVER_IN_ACTION_LOG=false
ALLOW_HIGH_RISK_ACTIONS=false

CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080
REMOTE_AREA_KEYWORDS=新疆,西藏,内蒙古,青海,宁夏,甘肃
UNSUPPORTED_AREA_KEYWORDS=香港,澳门,台湾,海外
