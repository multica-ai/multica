# Production environment for `pnpm package` / `pnpm build`.
# electron-vite (Vite under the hood) reads this automatically in
# production mode and inlines the values into the renderer bundle via
# import.meta.env.VITE_*. These are public URLs, not secrets.
#
# This is a self-hosting fork. The values below are intentionally blank
# so a desktop build can never accidentally ship pointing at the
# upstream hosted product (multica.ai). The build script in
# electron.vite.config.ts checks these at build-time and refuses to
# produce an artifact with empty values.
#
# To package the desktop app for your own server, override these in:
#
#   apps/desktop/.env.production.local   (gitignored)
#
# Example contents:
#
#   VITE_API_URL=https://api.example.com
#   VITE_WS_URL=wss://api.example.com/ws
#   VITE_APP_URL=https://app.example.com

# Backend API + websocket the desktop app talks to.
VITE_API_URL=
VITE_WS_URL=

# Public web app URL — used to build shareable links like "Copy link to
# issue" that users paste into Slack / messages. See platform/navigation.tsx.
VITE_APP_URL=
