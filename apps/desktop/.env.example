# Feature flag — when "true", the workspace settings page exposes a "GitLab"
# tab that lets a workspace admin connect a GitLab project. Mirrors the
# server-side MULTICA_GITLAB_ENABLED flag.
#
# Build-time only: VITE_* envs are inlined into the renderer bundle by Vite.
# Changing this requires repackaging the desktop app and shipping a new
# release. The server-side MULTICA_GITLAB_ENABLED is a runtime env (restart
# only) — keep them in sync at release time.
VITE_GITLAB_ENABLED=false
