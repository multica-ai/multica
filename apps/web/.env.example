# Feature flag — when "true", the workspace settings page exposes a "GitLab"
# tab that lets a workspace admin connect a GitLab project. Mirrors the
# server-side MULTICA_GITLAB_ENABLED flag.
#
# Build-time only: NEXT_PUBLIC_* envs are inlined into the client bundle by
# Next.js. Changing this requires a `pnpm --filter @multica/web build` and
# redeploy. The server-side MULTICA_GITLAB_ENABLED is a runtime env (restart
# only) — keep them in sync at deploy time.
NEXT_PUBLIC_GITLAB_ENABLED=false
