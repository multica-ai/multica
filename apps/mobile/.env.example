# Mobile env template.
#
# Copy to .env.development.local for local development. Phone builds must use
# an API URL reachable from the device; use your Mac's LAN IP for a real phone
# or 10.0.2.2 for the Android emulator, not localhost.

EXPO_PUBLIC_API_BASE_URL=https://<api-host>
EXPO_PUBLIC_WS_URL=wss://<api-host>/ws
