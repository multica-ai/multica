# packaging/docker/runtime/Dockerfile.base
#
# Shared base for all Multica agent runtime images: the `multica` binary plus
# full polyglot toolchains (Go, Rust + cargo-ndk, Node/pnpm, JDK/Kotlin,
# Android SDK + NDK, Python) and the debuggers/linters agents need at
# runtime. Per-provider images (Dockerfile.claude, etc.) extend this and
# add their agent CLI.
#
# Tradeoff: this is a fat image (~8-10 GB) on purpose. Once a node has the
# layers cached, pod startup is unaffected and agents working on polyglot
# repos (Go + Rust + Svelte + Kotlin + Android) don't need to install
# tooling per-job.
#
# Version pins for the language toolchains live in packaging/*-version text
# files and are passed in as --build-arg by packaging/scripts/build-images.sh.
# The ARGs have no defaults so an unpinned build fails loudly — matches the
# CLAUDE_CODE_VERSION pattern in Dockerfile.claude.

ARG GO_VERSION=1.26.4

# ── Build the multica binary from source ──────────────────────────────
FROM golang:${GO_VERSION}-bookworm AS multica-build
WORKDIR /src
COPY server/go.mod server/go.sum ./server/
RUN cd server && go mod download
COPY server/ ./server/
ARG VERSION=dev
ARG COMMIT=unknown
RUN cd server && CGO_ENABLED=0 go build \
      -ldflags "-s -w -X main.version=${VERSION} -X main.commit=${COMMIT}" \
      -o /out/multica ./cmd/multica

# ── Runtime base ──────────────────────────────────────────────────────
# node:22-trixie (Debian 13). The earlier node:22-bookworm base shipped a
# stale debian-archive keyring that didn't include Debian's mid-2026 archive
# signing key rotation, so `apt-get update` failed with "At least one
# invalid signature was encountered" on every build. Trixie is the current
# Debian stable and ships fresh keys.
FROM node:22-trixie

# Strict pins — build-images.sh passes these from packaging/*-version.
ARG RUST_VERSION
ARG KOTLIN_VERSION
ARG GOLANGCI_LINT_VERSION
ARG KTLINT_VERSION
ARG PNPM_VERSION
ARG KUBECTL_VERSION
ARG HELM_VERSION
ARG GH_VERSION
ARG WRANGLER_VERSION
ARG RCLONE_VERSION
# Android SDK/NDK component versions don't need a per-file pin (they rarely
# bump). Defaults stay in-Dockerfile and can be overridden via --build-arg.
ARG ANDROID_CMDLINE_TOOLS_VERSION=13114758
ARG ANDROID_PLATFORM_VERSION=36
ARG ANDROID_BUILD_TOOLS_VERSION=36.0.0
ARG ANDROID_NDK_VERSION=27.2.12479018
ARG CARGO_NDK_VERSION=3.5.4
RUN test -n "$RUST_VERSION"             || { echo "RUST_VERSION build arg is required" >&2; exit 1; } \
    && test -n "$KOTLIN_VERSION"        || { echo "KOTLIN_VERSION build arg is required" >&2; exit 1; } \
    && test -n "$GOLANGCI_LINT_VERSION" || { echo "GOLANGCI_LINT_VERSION build arg is required" >&2; exit 1; } \
    && test -n "$KTLINT_VERSION"        || { echo "KTLINT_VERSION build arg is required" >&2; exit 1; } \
    && test -n "$PNPM_VERSION"          || { echo "PNPM_VERSION build arg is required" >&2; exit 1; } \
    && test -n "$KUBECTL_VERSION"       || { echo "KUBECTL_VERSION build arg is required" >&2; exit 1; } \
    && test -n "$HELM_VERSION"          || { echo "HELM_VERSION build arg is required" >&2; exit 1; } \
    && test -n "$GH_VERSION"            || { echo "GH_VERSION build arg is required" >&2; exit 1; } \
    && test -n "$WRANGLER_VERSION"      || { echo "WRANGLER_VERSION build arg is required" >&2; exit 1; } \
    && test -n "$RCLONE_VERSION"        || { echo "RCLONE_VERSION build arg is required" >&2; exit 1; }

# Base apt packages: VCS, SSH, build/debug tooling, common dev utilities,
# JDK 21 for Kotlin/Android Gradle Plugin 8.x. (Trixie doesn't ship a JDK 17
# headless package; AGP 8.x is documented to run on JDK 21, and Kotlin
# requires only JDK 11+. JDK 17 source/target levels still build on JDK 21.)
RUN apt-get update && apt-get install -y --no-install-recommends \
      git \
      openssh-client \
      ca-certificates \
      gnupg \
      python3 \
      python3-pip \
      python3-venv \
      python-is-python3 \
      build-essential \
      pkg-config \
      make \
      cmake \
      ripgrep \
      fd-find \
      bat \
      curl \
      wget \
      jq \
      unzip \
      zip \
      gdb \
      lldb \
      strace \
      ltrace \
      lsof \
      procps \
      psmisc \
      netcat-openbsd \
      dnsutils \
      iputils-ping \
      net-tools \
      tcpdump \
      socat \
      tmux \
      vim-tiny \
      less \
      tree \
      file \
      htop \
      sudo \
      openjdk-21-jdk-headless \
    && ln -sf /usr/bin/fdfind /usr/local/bin/fd \
    && ln -sf /usr/bin/batcat /usr/local/bin/bat \
    && rm -rf /var/lib/apt/lists/*

ENV JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64

# ── Go toolchain + Go-based linters/debugger ──────────────────────────
COPY --from=multica-build /usr/local/go /usr/local/go
ENV GOROOT=/usr/local/go \
    GOPATH=/usr/local/gopath \
    GOBIN=/usr/local/gobin \
    PATH=/usr/local/gobin:/usr/local/go/bin:${PATH}
RUN mkdir -p "$GOPATH" "$GOBIN" \
    && go install github.com/go-delve/delve/cmd/dlv@latest \
    && go install golang.org/x/tools/gopls@latest \
    && go install honnef.co/go/tools/cmd/staticcheck@latest \
    && go install mvdan.cc/gofumpt@latest \
    && curl -fsSL "https://github.com/golangci/golangci-lint/releases/download/v${GOLANGCI_LINT_VERSION}/golangci-lint-${GOLANGCI_LINT_VERSION}-linux-amd64.tar.gz" \
       | tar -xz -C /tmp \
    && mv "/tmp/golangci-lint-${GOLANGCI_LINT_VERSION}-linux-amd64/golangci-lint" /usr/local/bin/ \
    && rm -rf "/tmp/golangci-lint-${GOLANGCI_LINT_VERSION}-linux-amd64" \
    && chmod -R a+rX "$GOPATH" "$GOBIN" \
    && rm -rf /root/.cache/go-build

# ── Rust toolchain + linters/LSP + cargo-ndk for Android cross-compile ─
ENV RUSTUP_HOME=/usr/local/rustup \
    CARGO_HOME=/usr/local/cargo \
    PATH=/usr/local/cargo/bin:${PATH}
RUN curl -fsSL https://sh.rustup.rs \
      | sh -s -- -y --no-modify-path --profile default --default-toolchain "${RUST_VERSION}" \
    && rustup component add clippy rustfmt rust-analyzer rust-src \
    && rustup target add \
         aarch64-linux-android \
         armv7-linux-androideabi \
         x86_64-linux-android \
         i686-linux-android \
    && cargo install --locked --version "${CARGO_NDK_VERSION}" cargo-ndk \
    && chmod -R a+rwX "$RUSTUP_HOME" "$CARGO_HOME" \
    && rm -rf /tmp/cargo-install*

# ── Kotlin compiler + ktlint ──────────────────────────────────────────
RUN curl -fsSL -o /tmp/kotlin.zip \
       "https://github.com/JetBrains/kotlin/releases/download/v${KOTLIN_VERSION}/kotlin-compiler-${KOTLIN_VERSION}.zip" \
    && unzip -q /tmp/kotlin.zip -d /opt \
    && rm /tmp/kotlin.zip \
    && ln -s /opt/kotlinc/bin/kotlinc /usr/local/bin/kotlinc \
    && ln -s /opt/kotlinc/bin/kotlin  /usr/local/bin/kotlin \
    && curl -fsSL -o /usr/local/bin/ktlint \
       "https://github.com/pinterest/ktlint/releases/download/${KTLINT_VERSION}/ktlint" \
    && chmod +x /usr/local/bin/ktlint

# ── Android SDK + NDK ─────────────────────────────────────────────────
ENV ANDROID_HOME=/opt/android-sdk \
    ANDROID_SDK_ROOT=/opt/android-sdk
RUN mkdir -p "$ANDROID_HOME/cmdline-tools" \
    && curl -fsSL -o /tmp/cmdline-tools.zip \
       "https://dl.google.com/android/repository/commandlinetools-linux-${ANDROID_CMDLINE_TOOLS_VERSION}_latest.zip" \
    && unzip -q /tmp/cmdline-tools.zip -d "$ANDROID_HOME/cmdline-tools" \
    && mv "$ANDROID_HOME/cmdline-tools/cmdline-tools" "$ANDROID_HOME/cmdline-tools/latest" \
    && rm /tmp/cmdline-tools.zip
ENV PATH="${ANDROID_HOME}/cmdline-tools/latest/bin:${ANDROID_HOME}/platform-tools:${PATH}"
RUN yes | sdkmanager --licenses > /dev/null \
    && sdkmanager --install \
         "platform-tools" \
         "platforms;android-${ANDROID_PLATFORM_VERSION}" \
         "build-tools;${ANDROID_BUILD_TOOLS_VERSION}" \
         "ndk;${ANDROID_NDK_VERSION}" \
    && chmod -R a+rX "$ANDROID_HOME"
ENV ANDROID_NDK_HOME=${ANDROID_HOME}/ndk/${ANDROID_NDK_VERSION} \
    ANDROID_NDK_ROOT=${ANDROID_HOME}/ndk/${ANDROID_NDK_VERSION}

# ── Node package managers via corepack ────────────────────────────────
RUN corepack enable \
    && corepack prepare "pnpm@${PNPM_VERSION}" --activate \
    && corepack prepare "yarn@stable" --activate

# ── pnpm install behavior for agent workers ───────────────────────────
# `pnpm install` in agent pods kept hanging on postinstall binary downloads
# (electron + playwright). Default the skip flags ON so a vanilla
# `pnpm install` completes inside a single agent turn. Tasks that genuinely
# need the binaries can unset the var and run `playwright install` /
# `electron-builder install-app-deps` explicitly.
ENV ELECTRON_SKIP_BINARY_DOWNLOAD=1 \
    PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

# ── Kubernetes CLI tooling (kubectl + helm) ───────────────────────────
RUN curl -fsSL "https://dl.k8s.io/release/v${KUBECTL_VERSION}/bin/linux/amd64/kubectl" \
       -o /usr/local/bin/kubectl \
    && chmod +x /usr/local/bin/kubectl \
    && kubectl version --client \
    && curl -fsSL "https://get.helm.sh/helm-v${HELM_VERSION}-linux-amd64.tar.gz" \
       | tar -xz -C /tmp \
    && mv /tmp/linux-amd64/helm /usr/local/bin/helm \
    && rm -rf /tmp/linux-amd64 \
    && chmod +x /usr/local/bin/helm \
    && helm version --short

# ── GitHub CLI (gh) ───────────────────────────────────────────────────
# Static binary from upstream releases. Agents that need GitHub-side actions
# (PR create/comment, issue ops) get gh on PATH. Auth is by GH_TOKEN env
# var injected from a K8s Secret at pod runtime — nothing baked in here.
RUN curl -fsSL "https://github.com/cli/cli/releases/download/v${GH_VERSION}/gh_${GH_VERSION}_linux_amd64.tar.gz" \
       | tar -xz -C /tmp \
    && mv "/tmp/gh_${GH_VERSION}_linux_amd64/bin/gh" /usr/local/bin/gh \
    && rm -rf "/tmp/gh_${GH_VERSION}_linux_amd64" \
    && chmod +x /usr/local/bin/gh \
    && gh --version

# ── Cloudflare tooling (wrangler + rclone) ────────────────────────────
# wrangler drives the Cloudflare API (Workers, R2 bucket create/list, etc.);
# rclone is the S3-compatible mover for R2 object sync. Both authenticate
# purely from env vars injected from a K8s Secret at pod runtime — no creds
# baked in here (same model as GH_TOKEN above). wrangler reads
# CLOUDFLARE_API_TOKEN; rclone reads AWS_*/endpoint env or an --s3-* config.
RUN npm install -g "wrangler@${WRANGLER_VERSION}" \
    && npm cache clean --force \
    && curl -fsSL "https://github.com/rclone/rclone/releases/download/v${RCLONE_VERSION}/rclone-v${RCLONE_VERSION}-linux-amd64.zip" \
       -o /tmp/rclone.zip \
    && unzip -q /tmp/rclone.zip -d /tmp \
    && mv "/tmp/rclone-v${RCLONE_VERSION}-linux-amd64/rclone" /usr/local/bin/rclone \
    && rm -rf /tmp/rclone.zip "/tmp/rclone-v${RCLONE_VERSION}-linux-amd64" \
    && chmod +x /usr/local/bin/rclone \
    && wrangler --version \
    && rclone --version | head -1

# Non-root user the daemon and agents run as.
RUN groupadd -g 1001 multica \
    && useradd -m -u 1001 -g 1001 -s /bin/bash multica

COPY --from=multica-build /out/multica /usr/local/bin/multica

# Pre-trust github.com so `git clone` over ssh doesn't prompt.
RUN mkdir -p /home/multica/.ssh \
    && ssh-keyscan github.com > /home/multica/.ssh/known_hosts 2>/dev/null \
    && chown -R multica:multica /home/multica/.ssh \
    && chmod 700 /home/multica/.ssh \
    && chmod 644 /home/multica/.ssh/known_hosts

USER multica
WORKDIR /home/multica
ENV HOME=/home/multica \
    GOPATH=/home/multica/go \
    PATH=/home/multica/go/bin:/usr/local/cargo/bin:/usr/local/gobin:/usr/local/go/bin:${ANDROID_HOME}/cmdline-tools/latest/bin:${ANDROID_HOME}/platform-tools:${PATH}

# Sanity: key tools resolve on PATH for the multica user.
RUN multica version || true \
    && go version \
    && dlv version \
    && golangci-lint --version \
    && rustc --version \
    && cargo --version \
    && cargo ndk --version \
    && rust-analyzer --version \
    && javac -version \
    && kotlinc -version 2>&1 \
    && ktlint --version \
    && pnpm --version \
    && yarn --version \
    && sdkmanager --version \
    && test -d "$ANDROID_NDK_HOME" \
    && kubectl version --client \
    && helm version --short \
    && gh --version \
    && wrangler --version \
    && rclone version | head -1
