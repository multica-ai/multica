# Multica daemon container configuration.
# Copy to .env.daemon and fill in real values:
#   docker compose -f docker-compose.daemon.yml --env-file .env.daemon up -d

# --- Required -------------------------------------------------------------

# Backend reachable from the daemon container. Use http(s):// — the daemon
# upgrades to ws(s) internally for the realtime channel.
MULTICA_SERVER_URL=https://multica.example.com

# Personal access token (mul_...) for the user the daemon should run as.
# Create one in the Multica web UI under Settings → Personal access tokens.
MULTICA_TOKEN=mul_replace_with_real_token

# --- Optional -------------------------------------------------------------

# Pin to a specific image version. Defaults to `latest`.
# MULTICA_VERSION=0.1.13

# Display name for the runtime in the Multica UI.
MULTICA_DAEMON_DEVICE_NAME=homelab-daemon-1
MULTICA_AGENT_RUNTIME_NAME=Cloud Daemon

# Tuning.
MULTICA_DAEMON_POLL_INTERVAL=3s
MULTICA_DAEMON_HEARTBEAT_INTERVAL=15s
MULTICA_DAEMON_MAX_CONCURRENT_TASKS=5

# Provider auth — passed through to spawned `claude` / `codex` processes.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
