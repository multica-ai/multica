# Multica daemon image — runs `multica daemon start --foreground` in a
# container so agent runtimes execute independently of any developer machine.
#
# Build:
#   docker build -f Dockerfile.daemon -t multica-daemon:latest .
#
# Run via docker-compose.daemon.yml (recommended) — see header of that file
# for required environment variables (MULTICA_SERVER_URL, MULTICA_TOKEN, ...).

# --- Build stage ---------------------------------------------------------
FROM golang:1.26-alpine AS builder

RUN apk add --no-cache git

WORKDIR /src

COPY server/go.mod server/go.sum ./server/
RUN cd server && go mod download

COPY server/ ./server/

ARG VERSION=dev
ARG COMMIT=unknown
RUN cd server && CGO_ENABLED=0 go build \
    -ldflags "-s -w -X main.version=${VERSION} -X main.commit=${COMMIT}" \
    -o bin/multica ./cmd/multica

# --- Runtime stage -------------------------------------------------------
FROM node:22-bookworm-slim

# git: required for repocache (bare clones + worktrees).
# ca-certificates: HTTPS to multica server and provider APIs.
# tini: PID 1 signal handling so the daemon shuts down cleanly.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        git ca-certificates tini \
    && rm -rf /var/lib/apt/lists/*

# Install at least one agent CLI so daemon startup does not abort.
# Pinning is intentionally loose — bump in CI when desired.
RUN npm install -g --no-fund --no-audit \
        @anthropic-ai/claude-code \
        @openai/codex \
    && npm cache clean --force

# Non-root runtime user. UID 1000 matches the default `node` user from the
# upstream image so bind-mounts from typical Linux hosts work without chown.
RUN useradd --create-home --shell /bin/bash --uid 1001 multica \
    && mkdir -p /home/multica/.multica /home/multica/multica_workspaces \
    && chown -R multica:multica /home/multica

COPY --from=builder /src/server/bin/multica /usr/local/bin/multica
COPY docker/daemon-entrypoint.sh /usr/local/bin/daemon-entrypoint.sh
RUN sed -i 's/\r$//' /usr/local/bin/daemon-entrypoint.sh \
    && chmod +x /usr/local/bin/daemon-entrypoint.sh

USER multica
WORKDIR /home/multica

# Persisted across restarts: CLI config (token, daemon UUID) and workspaces.
VOLUME ["/home/multica/.multica", "/home/multica/multica_workspaces"]

# Daemon-internal health endpoint (used by `multica daemon status`).
EXPOSE 19514

ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/daemon-entrypoint.sh"]
