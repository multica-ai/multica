APP_NAME=taobao-order-worker-v1
ENV=dev
HOST=0.0.0.0
PORT=8090

# Order event ingress secret. The upstream order system must send:
# X-Order-Event-Secret: dev-secret
TAOBAO_EVENT_SECRET=dev-secret

# Multica Autopilot Webhook URL. Copy it from the Autopilot settings.
MULTICA_AUTOPILOT_WEBHOOK_URL=

# Existing order API. Leave blank to use the built-in mock order source.
ORDER_API_BASE_URL=
ORDER_API_TOKEN=
ORDER_API_GET_ORDER_PATH=/api/orders/{tid}
ORDER_API_TIMEOUT_SECONDS=10

# false stores safe writes locally; true forwards safe writes to ORDER_API_BASE_URL.
ORDER_API_WRITE_THROUGH=false

# Local SQLite database for dedupe, idempotency, safe action records, and audit.
DEDUPE_DB_PATH=./data/order_worker.sqlite3

# 1.0 plaintext mode allows reading receiver name, phone, and full address.
ALLOW_PLAIN_RECEIVER_INFO=true

# 1.0 always blocks direct shipping, refunds, order close, address edit, and price edit.
ALLOW_HIGH_RISK_ACTIONS=false
