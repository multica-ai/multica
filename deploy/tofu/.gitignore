# Local state contains the RDS password. Never commit.
terraform.tfstate
terraform.tfstate.backup
*.tfstate
*.tfstate.*

# Variable overrides may contain secrets.
terraform.tfvars
*.auto.tfvars

# Provider + module caches.
.terraform/
.terraform.lock.hcl

# One-time RAM access key material generated by alicloud_ram_access_key.
.secrets/

# Plan outputs.
*.tfplan
*.plan
