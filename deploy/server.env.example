# 运行环境
APP_ENV=production
LOG_LEVEL=info

# 服务监听
PORT=8080
JWT_SECRET=replace-with-a-long-random-string

# 数据库
DATABASE_URL=postgres://multica:replace-me@127.0.0.1:5432/multica?sslmode=disable

# 单域部署
FRONTEND_ORIGIN=https://multica.ali.chenjiaming.org
CORS_ALLOWED_ORIGINS=https://multica.ali.chenjiaming.org
MULTICA_APP_URL=https://multica.ali.chenjiaming.org

# 邮箱验证码登录
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com

# Google OAuth（按需）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://multica.ali.chenjiaming.org/auth/callback

# 文件存储（按需）
S3_BUCKET=
S3_REGION=us-west-2
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY_SECRET=
CLOUDFRONT_PRIVATE_KEY=
CLOUDFRONT_DOMAIN=
COOKIE_DOMAIN=
