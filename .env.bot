# DingTalk notifications (optional)
# Enables Settings -> Notifications DingTalk account linking and external
# mention delivery. Leave empty to keep the channel disabled.
DINGTALK_CLIENT_ID=dingfibftxe2ayknnslf
DINGTALK_CLIENT_SECRET=Tm9DzOZa3naJMkIabKR8CrGGjihyqedD4b_yxUqHb8G9r1LqAQO8QSVMWTd-W_9-
DINGTALK_ROBOT_CODE=dingfibftxe2ayknnslf
# Optional overrides. Defaults match DingTalk OpenAPI endpoints used by the server.
DINGTALK_OAUTH_SCOPE="openid corpid Contact.User.Read"
DINGTALK_AUTH_URL=https://login.dingtalk.com/oauth2/auth
DINGTALK_TOKEN_URL=https://api.dingtalk.com/v1.0/oauth2/userAccessToken
DINGTALK_USERINFO_URL=https://api.dingtalk.com/v1.0/contact/users/me
DINGTALK_APP_TOKEN_URL=https://api.dingtalk.com/v1.0/oauth2/{corpId}/token
DINGTALK_MESSAGE_URL=https://api.dingtalk.com/v1.0/robot/oToMessages/batchSend
# Optional token encryption key for DingTalk access/refresh tokens. If unset,
# the backend derives encryption from JWT_SECRET.
DINGTALK_TOKEN_ENCRYPTION_KEY=

