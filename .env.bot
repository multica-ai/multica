RESEND_FROM_EMAIL=

# Google OAuth
GOOGLE_CLIENT_ID=28093689205-633mpk0mooj2nvu4ougg6l3978rh8iil.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_REDIRECT_URI=https://multica.wujieai.com/auth/callback
NEXT_PUBLIC_GOOGLE_CLIENT_ID=28093689205-633mpk0mooj2nvu4ougg6l3978rh8iil.apps.googleusercontent.com
# Proxy for Google OAuth API calls (token exchange & userinfo).
# Set when cluster nodes cannot reach googleapis.com directly.
GOOGLE_OAUTH_PROXY=http://127.0.0.1:7890

# DingTalk notifications (optional)
# Enables Settings -> Notifications DingTalk account linking and external
# mention delivery. Leave empty to keep the channel disabled.
DINGTALK_CLIENT_ID=dingfibftxe2ayknnslf
DINGTALK_CLIENT_SECRET=Tm9DzOZa3naJMkIabKR8CrGGjihyqedD4b_yxUqHb8G9r1LqAQO8QSVMWTd-W_9-
DINGTALK_ROBOT_CODE=dingfibftxe2ayknnslf
# Optional overrides. Defaults match DingTalk OpenAPI endpoints used by the server.
DINGTALK_OAUTH_SCOPE=openid corpid Contact.User.Read
DINGTALK_AUTH_URL=https://login.dingtalk.com/oauth2/auth
DINGTALK_TOKEN_URL=https://api.dingtalk.com/v1.0/oauth2/userAccessToken
DINGTALK_USERINFO_URL=https://api.dingtalk.com/v1.0/contact/users/me
DINGTALK_APP_TOKEN_URL=https://api.dingtalk.com/v1.0/oauth2/{corpId}/token
DINGTALK_MESSAGE_URL=https://api.dingtalk.com/v1.0/robot/oToMessages/batchSend
# Optional token encryption key for DingTalk access/refresh tokens. If unset,
# the backend derives encryption from JWT_SECRET.
DINGTALK_TOKEN_ENCRYPTION_KEY=

# S3 / CloudFront
S3_BUCKET=
S3_REGION=us-west-2
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY_SECRET=multica/cloudfront-signing-key
CLOUDFRONT_PRIVATE_KEY=
CLOUDFRONT_DOMAIN=
COOKIE_DOMAIN=.wujieai.com

# Frontend
FRONTEND_PORT=3000
FRONTEND_ORIGIN=https://multica.wujieai.com
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=wss://multica.wujieai.com/ws

# CORS
ALLOWED_ORIGINS=https://multica.wujieai.com

# Local file storage
LOCAL_UPLOAD_DIR=./data/uploads
LOCAL_UPLOAD_BASE_URL=https://multica.wujieai.com

# Remote API
REMOTE_API_URL=
